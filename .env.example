# Path to your karaoke songs directory on the host machine
SONGS_PATH=/path/to/your/karaoke/songs

# Path to your music library directory on the host machine (MP3 / FLAC)
MUSIC_PATH=/path/to/your/music/library

# Meilisearch master key — change this in production
MEILI_MASTER_KEY=karaoke-secret-key

# Login required to access the app — leave blank to disable auth
AUTH_USERNAME=
AUTH_PASSWORD=
